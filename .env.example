# ==============================================================================
# AI-HRMS ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and configure settings before running docker-compose
# ==============================================================================

# --- DATABASE CONFIGURATION (POSTGRESQL) ---
POSTGRES_USER=hrms_admin
POSTGRES_PASSWORD=hrms_secure_password_2026
POSTGRES_DB=hrms_prod
POSTGRES_HOST=database
POSTGRES_PORT=5432
DATABASE_URL=postgresql://hrms_admin:hrms_secure_password_2026@database:5432/hrms_prod

# --- BACKEND APPLICATION CONFIGURATION (FASTAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
DEBUG=true

# Security & JWT Tokens
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=e6f81a7d6a5d7c3b9b4f5e0a6d2c4e8f0a2d3c5b8e9f1a2b3c4d5e6f7a8b9c0d
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- FRONTEND CONFIGURATION (NEXT.JS) ---
# For development via Docker, it points to local gateway or docker network service
# For browser client-side calls, it needs the external URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- AI & EMBEDDINGS CONFIGURATION ---
# Base URL for Ollama local LLM instance
OLLAMA_BASE_URL=http://ollama:11434
# LLM Model used for general assistant tasks
LLM_MODEL=llama3.1:8b
# Embedding model for vector storage mapping
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chroma Vector Database Config
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_DB_PATH=/chromadb/data
